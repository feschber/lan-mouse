<?xml version="1.0" encoding="UTF-8"?>
<interface>
	<template class="KeyRow" parent="AdwExpanderRow">
		<child type="suffix">
			<object class="GtkButton" id="delete_button">
				<property name="valign">center</property>
				<property name="halign">end</property>
				<property name="tooltip-text" translatable="yes">Revoke authorization</property>
				<property name="icon-name">edit-delete-symbolic</property>
				<style>
					<class name="flat"/>
				</style>
			</object>
		</child>
		<!-- natural-scroll toggle -->
		<child>
			<object class="AdwActionRow">
				<property name="title" translatable="yes">Natural Scrolling</property>
				<property name="subtitle" translatable="yes">Sign-invert scroll deltas forwarded from this peer before injection.</property>
				<child type="suffix">
					<object class="GtkSwitch" id="natural_scroll_switch">
						<property name="valign">center</property>
					</object>
				</child>
			</object>
		</child>
		<!-- mouse-sensitivity numeric -->
		<child>
			<object class="AdwActionRow">
				<property name="title" translatable="yes">Mouse Sensitivity</property>
				<property name="subtitle" translatable="yes">Linear multiplier applied to motion deltas from this peer. 1.0 = passthrough.</property>
				<child type="suffix">
					<object class="GtkSpinButton" id="sensitivity_spin">
						<property name="valign">center</property>
						<property name="numeric">true</property>
						<property name="digits">2</property>
						<property name="adjustment">
							<object class="GtkAdjustment">
								<property name="lower">0.1</property>
								<property name="upper">5.0</property>
								<property name="step-increment">0.1</property>
								<property name="page-increment">0.5</property>
								<property name="value">1.0</property>
							</object>
						</property>
					</object>
				</child>
			</object>
		</child>
	</template>
</interface>
